{
  "name": "tally",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal finance app for Pi 5 — CSV import, GPT advice, budgets, receipts",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch --no-warnings src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx --no-warnings src/server/index.ts",
    "db:reset": "tsx src/server/db/reset.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.3",
    "papaparse": "^5.4.1",
    "sharp": "^0.33.5",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "lucide-react": "^0.451.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
